{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@dietrichgeber/ponytail"],
  "mcp": {
    "vercel": {
      "type": "local",
      "command": ["node", ".opencode/mcp-servers/vercel-server.mjs"],
      "enabled": true,
      "timeout": 300000
    },
    "neon": {
      "type": "local",
      "command": ["node", ".opencode/mcp-servers/neon-server.mjs"],
      "enabled": true,
      "timeout": 30000
    },
    "supabase": {
      "type": "local",
      "command": ["node", ".opencode/mcp-servers/supabase-server.mjs"],
      "enabled": true,
      "timeout": 60000
    }
  },
  "agent": {
    "build": {
      "prompt": "You are a lazy senior developer working on BerojgarDegreeWala. Before coding, check opencode.json MCP servers for Vercel/Supabase/Neon operations. All auth is pre-configured."
    }
  }
}
