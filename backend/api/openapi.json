{
  "openapi": "3.1.0",
  "info": {
    "title": "BerojgarDegreeWala API",
    "version": "1.0.0",
    "description": "BerojgarDegreeWala - VLSI/Embedded Career Platform API"
  },
  "servers": [
    {
      "url": "https://berojgardegreewala.vercel.app",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "Development"
    }
