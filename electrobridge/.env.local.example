# ── Site URL ─────────────────────────────────────────────────────────────────
# CRITICAL for email verification & OAuth redirects. Set to your deployed domain:
#   Development: http://localhost:3000 (default fallback)
#   Production:  https://electrobridge.vercel.app (Vercel auto-sets NEXT_PUBLIC_VERCEL_URL)
# You can also set NEXT_PUBLIC_APP_URL as an alternative name.
NEXT_PUBLIC_SITE_URL=

# ── Supabase Primary (main DB: opportunities, news, community, auth) ──────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Auth settings (must match in Supabase Dashboard → Authentication → Settings):
#   Site URL:         https://electrobridge.vercel.app
#   Redirect URLs:    https://electrobridge.vercel.app/auth/callback
#                     http://localhost:3000/auth/callback
#   Email templates → Confirmation:  {{ .ConfirmationURL }}
#
# Google OAuth (Supabase Dashboard → Authentication → Providers → Google):
#   1. Enable Google provider
#   2. Set Client ID & Client Secret from Google Cloud Console
#   3. Add to Google Cloud Console → Credentials → OAuth 2.0 Web Client:
#      Authorized JavaScript origins: https://electrobridge.vercel.app
#      Authorized redirect URIs:      https://<project>.supabase.co/auth/v1/callback

# ── Supabase Secondary (Netlify account, news archive overflow) ──────────
SUPABASE_2_URL=your_supabase_2_url
SUPABASE_2_ANON_KEY=your_supabase_2_anon_key
SUPABASE_2_SERVICE_ROLE_KEY=your_supabase_2_service_role_key

# ── Neon Primary (analytics, ai_usage_log, link_check_logs) ──────────────
NEON_1_DATABASE_URL=your_neon_1_database_url

# ── Neon Secondary (read replica, opportunities_mirror) ───────────────────
NEON_2_DATABASE_URL=your_neon_2_database_url

# ── Admin & Auth ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_PASSWORD=your_strong_password
CRON_SECRET=your_random_secret

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=

# ── AI Providers ──────────────────────────────────────────────────────────
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
CLOUDFLARE_AI_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
AWS_BEARER_TOKEN_BEDROCK=

# ── Sentry (error tracking) ──────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
