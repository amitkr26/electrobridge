{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "BerojgarDegreeWala Environment Variables",
  "type": "object",
  "required": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "ADMIN_PASSWORD",
    "CRON_SECRET",
    "SCRAPER_SECRET"
  ],
  "properties": {
    "NEXT_PUBLIC_SUPABASE_URL": { "type": "string", "format": "uri", "description": "Supabase DB1 project URL" },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": { "type": "string", "description": "Supabase DB1 anon key" },
    "SUPABASE_SERVICE_ROLE_KEY": { "type": "string", "description": "Supabase DB1 service role key (secret)" },
    "NEXT_PUBLIC_SUPABASE_URL_2": { "type": "string", "format": "uri", "description": "Supabase DB2 project URL" },
    "SUPABASE_SERVICE_ROLE_KEY_2": { "type": "string", "description": "Supabase DB2 service role key" },
    "NEXT_PUBLIC_SITE_URL": { "type": "string", "format": "uri", "default": "http://localhost:3000" },
    "ADMIN_PASSWORD": { "type": "string", "description": "Admin dashboard password" },
    "CRON_SECRET": { "type": "string", "description": "Bearer token for cron endpoints" },
    "SCRAPER_SECRET": { "type": "string", "description": "Bearer token for backend scraper" },
    "BACKEND_URL": { "type": "string", "format": "uri", "description": "Render backend URL" },
    "NEXT_PUBLIC_POSTHOG_KEY": { "type": "string", "description": "PostHog analytics key" },
    "RESEND_API_KEY": { "type": "string", "description": "Resend email API key" },
    "SENTRY_AUTH_TOKEN": { "type": "string", "description": "Sentry auth token" },
    "UPSTASH_REDIS_URL": { "type": "string", "format": "uri", "description": "Upstash Redis URL" },
    "UPSTASH_REDIS_TOKEN": { "type": "string", "description": "Upstash Redis token" },
    "GROQ_API_KEY": { "type": "string", "description": "Groq AI provider key" },
    "OPENROUTER_API_KEY": { "type": "string", "description": "OpenRouter AI provider key" },
    "CLOUDFLARE_AI_TOKEN": { "type": "string", "description": "Cloudflare Workers AI token" },
    "GEMINI_API_KEY": { "type": "string", "description": "Google Gemini API key" },
    "NVIDIA_NIM_API_KEY": { "type": "string", "description": "NVIDIA NIM API key" },
    "HF_TOKEN": { "type": "string", "description": "HuggingFace token" },
    "AWS_BEDROCK_REGION": { "type": "string", "description": "AWS Bedrock region" },
    "AWS_ACCESS_KEY_ID": { "type": "string", "description": "AWS access key" },
    "AWS_SECRET_ACCESS_KEY": { "type": "string", "description": "AWS secret key" },
    "GOOGLE_CLIENT_ID": { "type": "string", "description": "Google OAuth client ID" },
    "GOOGLE_CLIENT_SECRET": { "type": "string", "description": "Google OAuth client secret" },
    "GITHUB_CLIENT_ID": { "type": "string", "description": "GitHub OAuth client ID" },
    "GITHUB_CLIENT_SECRET": { "type": "string", "description": "GitHub OAuth client secret" },
    "VERCEL_TOKEN": { "type": "string", "description": "Vercel deployment token" },
    "NEON_DATABASE_URL": { "type": "string", "format": "uri", "description": "Neon analytics connection string" }
  }
}
